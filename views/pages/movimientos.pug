extends ../layouts/base

block contenido
  h2 Movimientos de Stock

  if movimientos.length === 0
    p No hay movimientos registrados.
  else
    table
      thead
        tr
          th Producto
          th Tipo
          th Cantidad
          th Impacto
          th Motivo
          th Fecha
      tbody
        each m in movimientos
          tr(class=m.tipo === 'egreso' ? 'egreso' : 'ingreso')
            td #{m.productoNombre || (m.productoId && m.productoId.nombre) || '-'}
            td #{m.tipo}
            td #{m.cantidad}
            td #{m.impacto}
            td #{m.motivo || '-'}
            td #{new Date(m.createdAt).toLocaleString('es-AR')}
