extends ../layouts/base

block contenido
  a.volver(href='/') ← Volver al listado

  h2 #{producto.nombre}

  if producto.stockBajo
    p.alerta 🔴 Este producto tiene stock bajo

  table
    tr
      th Stock actual
      td #{producto.stock}
    tr
      th Precio
      td $#{producto.precio}
    tr
      th Unidad
      td #{producto.unidad}
    tr
      th Lote
      td #{producto.lote}
    tr
      th Vencimiento
      td #{producto.vencimiento ? new Date(producto.vencimiento).toLocaleDateString('es-AR') : '-'}
    tr
      th Estado
      td #{producto.estado}

  h3 Historial de movimientos

  if movimientos.length === 0
    p No hay movimientos registrados para este producto.
  else
    table
      thead
        tr
          th Tipo
          th Cantidad
          th Impacto
          th Motivo
          th Fecha
      tbody
        each m in movimientos
          tr(class=m.tipo === 'egreso' ? 'egreso' : 'ingreso')
            td #{m.tipo}
            td #{m.cantidad}
            td #{m.impacto}
            td #{m.motivo || '-'}
            td #{new Date(m.createdAt).toLocaleString('es-AR')}
